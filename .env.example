# Local Development Environment Variables
# Copy this to .env and fill in your actual values (DO NOT COMMIT .env!)

# Database
DB_NAME=assetflow
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password_here
DB_HOST=localhost

JWT_SECRET_KEY=your_jwt_secret_key_here_min_44_chars_base64

# Optional
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000